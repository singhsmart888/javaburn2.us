---
import Layout from "../layouts/Layout.astro";
const title = "About Java Burn 2.0 | Coffee Metabolism Booster Story";
const description = "Discover the Java Burn 2.0 story — how 6 clinically studied ingredients were combined to enhance coffee's natural metabolism and sustained energy support.";
const keywords = "Java Burn, Java Burn 2.0 company, Java Burn 2.0 brand story, Java Burn 2.0 founders, Java Burn 2.0 metabolism mission, Java Burn 2.0 ingredients science, Java Burn 2.0 manufacturing standards, Java Burn 2.0 quality assurance, Java Burn 2.0 coffee research, Java Burn 2.0 formulation team, Java Burn 2.0 supplement maker, Java Burn 2.0 history, Java Burn 2.0 overview, Java Burn 2.0 background, Java Burn 2.0 nutritional science";
const ogDescription = "Discover Java Burn 2.0's journey — a research-backed coffee metabolism formula built on 6 clinically studied ingredients and rigorous quality standards.";
const extraSchemas = [{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://javaburn2.us/"}, {"@type": "ListItem", "position": 2, "name": "About Us", "item": "https://javaburn2.us/about-us"}]}, {"@context": "https://schema.org", "@type": "AboutPage", "name": "About Java Burn 2.0", "url": "https://javaburn2.us/about-us", "description": "Java Burn 2.0 delivers a coffee-enhancing metabolism formula grounded in nutritional research, combining 6 natural ingredients to support metabolic function, energy, and overall wellness.", "mainEntity": {"@type": "Organization", "name": "Java Burn 2.0", "url": "https://javaburn2.us/", "description": "Java Burn 2.0 provides a research-validated coffee metabolism formula featuring Chlorogenic Acid, Green Tea, Chromium, L-Carnitine, L-Theanine and Vitamin Complex manufactured in the USA.", "foundingDate": "2025", "knowsAbout": ["Metabolism Support", "Weight Management", "Coffee Enhancement", "Chlorogenic Acid", "Green Tea Extract", "Chromium", "L-Carnitine", "L-Theanine"], "sameAs": ["https://javaburn2.us/"]}}];
---
<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogDescription={ogDescription}
  extraSchemas={extraSchemas}
>
  <main id="main">
      <section class="kw-hero">
        <div class="trimology-container">
          <div class="kw-hero-inner">
            <div class="kw-hero-text">
              <h1>About Java Burn 2.0</h1>
              <p>Java Burn 2.0 is a U.S.-based wellness brand committed to helping adults support their metabolism, energy, and weight management goals through a simple, tasteless coffee-enhancing formula.</p>
            </div>
            <div class="kw-hero-img">
              <img src="/assets/images/6-bottles.webp" alt="Java Burn 2.0" width="400" height="400" loading="lazy">
            </div>
          </div>
        </div>
      </section>
    
      <section class="kw-section">
        <h2>Our Mission</h2>
        <p>We believe that small, consistent habits create lasting results. Java Burn 2.0 was created to make metabolic support as effortless as adding one tasteless packet to your morning coffee.</p>
    
        <h2>Quality Standards</h2>
        <p>Every pouch of Java Burn 2.0 is manufactured in an FDA-registered, GMP-certified facility in the United States. The formula is non-GMO, vegetarian, gluten-free, and made without artificial fillers.</p>
    
        <h2>Research-Backed Ingredients</h2>
        <p>Java Burn 2.0 combines six clinically studied nutrients: Chlorogenic Acid, Green Tea Extract (Camellia Sinensis), Chromium, L-Carnitine, L-Theanine, and a Vitamin Complex. Each ingredient was selected for its role in metabolism, energy, and overall wellness.</p>
    
        <h2>Customer-First Promise</h2>
        <p>We stand behind Java Burn 2.0 with a 60-day money-back satisfaction guarantee. If you are not completely satisfied with your results, our U.S.-based support team is here to help.</p>
      </section>
    </main>
</Layout>
