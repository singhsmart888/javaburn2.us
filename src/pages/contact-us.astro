---
import Layout from "../layouts/Layout.astro";
const title = "Reach Out to Java Burn 2.0™ | Customer Support & Assistance";
const description = "Need help with Java Burn 2.0? Connect with our U.S.-based support team for product questions, order help, and refund inquiries. Fast, friendly assistance.";
const keywords = "Java Burn, reach Java Burn 2.0, Java Burn 2.0 assistance, Java Burn 2.0 customer care, Java Burn 2.0 helpdesk, Java Burn 2.0 coffee supplement support, Java Burn 2.0 enquiry, Java Burn 2.0 email address, get help Java Burn 2.0, Java Burn 2.0 support team, Java Burn 2.0 order assistance, Java Burn 2.0 refund inquiry, Java Burn 2.0 return help, Java Burn 2.0 metabolic wellness contact, Java Burn 2.0 buyer support";
const ogDescription = "Connect with Java Burn 2.0's U.S.-based support team for product questions, order assistance, return requests, and general inquiries. We're here to help.";
const extraSchemas = [{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://javaburn2.us/"}, {"@type": "ListItem", "position": 2, "name": "Contact Us", "item": "https://javaburn2.us/contact-us"}]}];
---
<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogDescription={ogDescription}
  extraSchemas={extraSchemas}
>
  <main id="main">
      <section class="kw-hero">
        <div class="trimology-container">
          <div class="kw-hero-inner">
            <div class="kw-hero-text">
              <h1>Contact Java Burn 2.0</h1>
              <p>Have questions about Java Burn 2.0? Our U.S.-based support team is ready to help with product, order, and refund inquiries.</p>
            </div>
            <div class="kw-hero-img">
              <img src="/assets/images/6-bottles.webp" alt="Contact Java Burn 2.0" width="400" height="400" loading="lazy">
            </div>
          </div>
        </div>
      </section>
    
      <section class="kw-section">
        <h2>Get in Touch</h2>
        <p>We typically respond within 24-48 business hours. For fastest service regarding an existing order, please include your order confirmation number.</p>
    
        <div class="kw-quick-facts">
          <table>
            <tr><td>Support Email</td><td><a href="mailto:support@javaburn2.us">support@javaburn2.us</a></td></tr>
            <tr><td>Order Partner</td><td>BuyGoods, a Delaware corporation</td></tr>
            <tr><td>Response Time</td><td>24-48 hours (Monday-Friday)</td></tr>
            <tr><td>Refund Window</td><td>60 days from purchase date</td></tr>
          </table>
        </div>
    
        <h2>Frequently Asked Contact Questions</h2>
        <div class="kw-faq-list">
          <div class="kw-faq-item">
            <div class="kw-faq-question">How do I track my order?</div>
            <div class="kw-faq-answer">Visit our <a href="/order-tracking">Order Tracking</a> page and enter your order details to see real-time shipping updates.</div>
          </div>
          <div class="kw-faq-item">
            <div class="kw-faq-question">How do I request a refund?</div>
            <div class="kw-faq-answer">You can request a refund within 60 days by contacting our support team or the retailer BuyGoods directly.</div>
          </div>
          <div class="kw-faq-item">
            <div class="kw-faq-question">Can I change my order after purchase?</div>
            <div class="kw-faq-answer">Orders are processed quickly. Contact support as soon as possible and we will do our best to assist.</div>
          </div>
        </div>
      </section>
    </main>
</Layout>
