---
import Layout from "../layouts/Layout.astro";
const title = "Page Unavailable - Java Burn 2.0™ Metabolic Support";
const description = "This page could not be located. Head to the Java Burn 2.0 official website to explore our metabolic wellness supplements and premium weight management resources.";
const extraSchemas = [{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://javaburn2.us/"}, {"@type": "ListItem", "position": 2, "name": "Page Not Found"}]}];
const noindex = true;
---
<Layout
  title={title}
  description={description}
  extraSchemas={extraSchemas}
  noindex={true}
>
  <main id="main">
      <section class="kw-section" style="text-align:center;padding:80px 20px;">
        <h1>404 — Page Not Found</h1>
        <p>Sorry, the page you are looking for does not exist or has been moved.</p>
        <a class="kw-cta" href="/">Go to Homepage</a>
      </section>
    </main>
</Layout>
