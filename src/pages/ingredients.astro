---
import Layout from "../layouts/Layout.astro";
const title = "Java Burn 2.0 Ingredients – 6 Metabolic Support Nutrients";
const description = "Explore Java Burn 2.0's 6 natural ingredients that transform your morning coffee into a metabolism-boosting ritual. Discover the science inside each packet.";
const keywords = "Java Burn, Java Burn 2.0 ingredients, Java Burn 2.0 formula, Java Burn 2.0 Chlorogenic Acid, Java Burn 2.0 Green Tea, Java Burn 2.0 Chromium, Java Burn 2.0 L-Carnitine, Java Burn 2.0 L-Theanine, Java Burn 2.0 Vitamin Complex, Java Burn 2.0 supplement facts, what is in Java Burn 2.0, Java Burn 2.0 composition, Java Burn 2.0 metabolism, Java Burn 2.0 coffee enhancer";
const ogDescription = "Full breakdown of Java Burn 2.0's 6 natural ingredients. Chlorogenic Acid, Green Tea, Chromium, L-Carnitine, L-Theanine & Vitamin Complex.";
