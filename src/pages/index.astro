       <script>
       /* Java Burn 2.0 Countdown Timer - 10min rolling */
       (function(){
         var key='vf_timer_end_10m';
         var stored=localStorage.getItem(key);
         var end=stored?parseInt(stored,10):0;
         var now=Date.now();
         if(!stored||end<=now||(end-now)>600000){end=now+600000;localStorage.setItem(key,end);}
         function pad(n){return n<10?'0'+n:n;}
         var elM=document.getElementById('vf-cd-m');
         var elS=document.getElementById('vf-cd-s');
         var banM=document.getElementById('vf-banner-m');
         var banS=document.getElementById('vf-banner-s');
         function tick(){
           var rem=end-Date.now();
           if(rem<=0){rem=0;localStorage.removeItem(key);}
           var m=Math.floor(rem/60000);
           var s=Math.floor((rem%60000)/1000);
           var ms = pad(m); var ss = pad(s);
           if(elM)elM.textContent=ms;
           if(elS)elS.textContent=ss;
           if(banM)banM.textContent=ms;
           if(banS)banS.textContent=ss;
           if(rem>0)requestAnimationFrame(tick);
         }
         tick();
       })();
       </script>   <script>
       /* Banner auto-position: locks banner directly below the navbar regardless of any
          elements added above (trust bars, announcement strips, etc.). Rebrand-proof. */
       (function(){
         var banner = document.querySelector('.vf-sticky-banner');
         var navbar = document.querySelector('.trimology-navbar') || document.querySelector('nav');
         if(!banner || !navbar) return;
         var mq = window.matchMedia('(max-width: 991px)');
         function position(){
           if(mq.matches){ banner.style.top = ''; return; }
           var rect = navbar.getBoundingClientRect();
           var top = Math.max(0, rect.bottom);
           banner.style.top = top + 'px';
         }
         position();
         window.addEventListener('resize', position, {passive:true});
         window.addEventListener('scroll', position, {passive:true});
         window.addEventListener('load', position);
         setTimeout(position, 300);
         setTimeout(position, 1000);
       })();
       </script>
