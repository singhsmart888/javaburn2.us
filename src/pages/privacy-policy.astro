---
import Layout from "../layouts/Layout.astro";
const title = "Java Burn 2.0™ Privacy Notice | How We Protect Your Data";
const description = "Java Burn 2.0 Privacy Notice. Understand how we gather, handle, and safeguard your personal information when you browse our site or purchase our products.";
const keywords = "Java Burn, Java Burn 2.0 privacy notice, Java Burn 2.0 data handling, Java Burn 2.0 personal data, Java Burn 2.0 privacy practices, Java Burn 2.0 information collection, Java Burn 2.0 cookie usage, Java Burn 2.0 data safety, Java Burn 2.0 GDPR compliance, Java Burn 2.0 user data rights, Java Burn 2.0 supplement privacy, Java Burn 2.0 site privacy, Java Burn 2.0 data protection";
const extraSchemas = [{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://javaburn2.us/"}, {"@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": "https://javaburn2.us/privacy-policy"}]}];
---
<Layout
  title={title}
  description={description}
  keywords={keywords}
  extraSchemas={extraSchemas}
>
  <main id="main">
      <section class="kw-section">
        <h1>Privacy Policy</h1>
        <p>At Java Burn 2.0, we take your privacy seriously. This Privacy Policy explains how we collect, use, and protect your personal information when you visit our website or make a purchase.</p>
    
        <h2>Information We Collect</h2>
        <p>We may collect personal information such as your name, email address, shipping address, phone number, and payment details when you place an order or contact us.</p>
    
        <h2>How We Use Your Information</h2>
        <ul>
          <li>To process and fulfill your orders</li>
          <li>To provide customer support</li>
          <li>To send order updates and promotional emails</li>
          <li>To improve our website and services</li>
        </ul>
    
        <h2>Third-Party Services</h2>
        <p>We use trusted third-party services for payment processing, order fulfillment, and analytics. These partners are contractually obligated to protect your data.</p>
    
        <h2>Your Rights</h2>
        <p>You have the right to access, update, or request deletion of your personal information. Contact us at support@javaburn.com for any privacy-related requests.</p>
      </section>
    </main>
</Layout>
