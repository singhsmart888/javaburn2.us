---
import Layout from "../layouts/Layout.astro";
const title = "Track Your Java Burn 2.0™ Order | Shipping & Delivery";
const description = "Monitor your Java Burn 2.0 order in real time. Locate your tracking number, verify shipping progress, and get delivery updates for your metabolic wellness formula.";
const keywords = "Java Burn, Java Burn 2.0 shipment tracking, Java Burn 2.0 delivery status, monitor Java Burn 2.0 order, Java Burn 2.0 tracking code, Java Burn 2.0 coffee supplement shipping, Java Burn 2.0 dispatch status, Java Burn 2.0 parcel tracking, Java Burn 2.0 order update, Java Burn 2.0 BuyGoods shipment, Java Burn 2.0 estimated delivery, Java Burn 2.0 transit time, locate my Java Burn 2.0 order, Java Burn 2.0 carrier tracking, Java Burn 2.0 package status";
const ogDescription = "Monitor your Java Burn 2.0 shipment status in real time. Locate your tracking code and stay informed about your metabolic wellness supplement delivery.";
const extraSchemas = [{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://javaburn2.us/"}, {"@type": "ListItem", "position": 2, "name": "Order Tracking", "item": "https://javaburn2.us/order-tracking"}]}];
---
<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogDescription={ogDescription}
  extraSchemas={extraSchemas}
>
  <main id="main">
      <section class="kw-hero">
        <div class="trimology-container">
          <div class="kw-hero-inner">
            <div class="kw-hero-text">
              <h1>Track Your Java Burn 2.0 Order</h1>
              <p>Enter your order details below to check the status of your Java Burn 2.0 shipment.</p>
            </div>
            <div class="kw-hero-img">
              <img src="/assets/images/3-bottles.webp" alt="Order Tracking" width="400" height="400" loading="lazy">
            </div>
          </div>
        </div>
      </section>
    
      <section class="kw-section">
        <h2>How to Track</h2>
        <p>After your order ships, you will receive an email with your tracking number and a link to the carrier's tracking page. You can also track your order through the BuyGoods order portal.</p>
    
        <div class="kw-quick-facts">
          <table>
            <tr><td>Order Lookup</td><td><a href="https://www.buygoods.com/lookup.php" rel="nofollow noopener" target="_blank">BuyGoods Order Lookup</a></td></tr>
            <tr><td>Support Email</td><td><a href="mailto:support@javaburn.com">support@javaburn.com</a></td></tr>
            <tr><td>Typical Delivery</td><td>5-10 business days within the USA</td></tr>
          </table>
        </div>
    
        <h2>Tracking Tips</h2>
        <ul>
          <li>Check your spam folder if you did not receive a shipping confirmation</li>
          <li>Allow 24-48 hours for tracking information to update after shipment</li>
          <li>Contact support if your tracking number is not working after 48 hours</li>
        </ul>
      </section>
    </main>
</Layout>
