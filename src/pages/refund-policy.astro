---
import Layout from "../layouts/Layout.astro";
const title = "Java Burn 2.0™ Refund & Return Policy | 60-Day Guarantee";
const description = "Java Burn 2.0's 60-Day Satisfaction Guarantee explained. Not happy with your results? Request a hassle-free refund within 60 days. Full details inside.";
const keywords = "Java Burn, Java Burn 2.0 return policy, Java Burn 2.0 guarantee details, Java Burn 2.0 60 day promise, Java Burn 2.0 refund eligibility, Java Burn 2.0 metabolic wellness guarantee, Java Burn 2.0 money back policy, Java Burn 2.0 refund steps, Java Burn 2.0 return instructions, Java Burn 2.0 customer guarantee, how to get Java Burn 2.0 refund, Java Burn 2.0 BuyGoods return, Java Burn 2.0 supplement guarantee, Java Burn 2.0 satisfaction policy";
const ogDescription = "Java Burn 2.0's 60-Day Satisfaction Guarantee fully explained. Not happy with your results? Request a hassle-free refund within 60 days of purchase.";
const extraSchemas = [{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://javaburn2.us/"}, {"@type": "ListItem", "position": 2, "name": "Refund Policy", "item": "https://javaburn2.us/refund-policy"}]}];
---
<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogDescription={ogDescription}
  extraSchemas={extraSchemas}
>
  <main id="main">
      <section class="kw-section">
        <h1>Refund Policy</h1>
        <p>Java Burn 2.0 is backed by a 60-day money-back satisfaction guarantee. If you are not completely satisfied with your purchase, you may request a full refund within 60 days of your order date.</p>
    
        <h2>How to Request a Refund</h2>
        <ol>
          <li>Locate your order confirmation email</li>
          <li>Contact our support team at support@javaburn2.us or the retailer BuyGoods</li>
          <li>Provide your order number and reason for refund</li>
          <li>Follow the return instructions provided by our support team</li>
        </ol>
    
        <h2>Refund Eligibility</h2>
        <ul>
          <li>Refund requests must be made within 60 days of purchase</li>
          <li>Both opened and unopened products may qualify</li>
          <li>Shipping costs are non-refundable unless the return is due to our error</li>
        </ul>
    
        <h2>Processing Time</h2>
        <p>Refunds are typically processed within 5-10 business days after the returned product is received. The refund will be issued to the original payment method.</p>
      </section>
    </main>
</Layout>
