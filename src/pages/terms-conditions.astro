---
import Layout from "../layouts/Layout.astro";
const title = "Java Burn 2.0™ Terms of Service | Usage & Legal Information";
const description = "Java Burn 2.0 Terms of Service. Understand our website usage rules, health disclaimers, purchase policies, and our 60-day satisfaction guarantee.";
const keywords = "Java Burn, Java Burn 2.0 usage terms, Java Burn 2.0 service agreement, Java Burn 2.0 legal information, Java Burn 2.0 health notice, Java Burn 2.0 metabolic wellness terms, Java Burn 2.0 supplement disclaimer, Java Burn 2.0 return terms, Java Burn 2.0 guarantee conditions, Java Burn 2.0 policies, Java Burn 2.0 property rights, Java Burn 2.0 liability notice, Java Burn 2.0 website rules";
const ogDescription = "Java Burn 2.0 Terms of Service. Understand our website usage rules, health disclaimers, purchase policies, and our 60-day satisfaction guarantee terms.";
const extraSchemas = [{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://javaburn2.us/"}, {"@type": "ListItem", "position": 2, "name": "Terms & Conditions", "item": "https://javaburn2.us/terms-conditions"}]}];
---
<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogDescription={ogDescription}
  extraSchemas={extraSchemas}
>
  <main id="main">
      <section class="kw-section">
        <h1>Terms & Conditions</h1>
        <p>By accessing and using the Java Burn 2.0 website, you agree to be bound by these Terms & Conditions. Please read them carefully before making a purchase.</p>
    
        <h2>Use of Website</h2>
        <p>You agree to use this website for lawful purposes only. You may not use the site to transmit harmful code, engage in fraudulent activity, or infringe on intellectual property rights.</p>
    
        <h2>Product Information</h2>
        <p>The statements on this website have not been evaluated by the Food and Drug Administration. Java Burn 2.0 is not intended to diagnose, treat, cure, or prevent any disease.</p>
    
        <h2>Purchases & Refunds</h2>
        <p>All purchases are subject to our <a href="/refund-policy">Refund Policy</a>. We offer a 60-day money-back satisfaction guarantee on qualifying orders.</p>
    
        <h2>Limitation of Liability</h2>
        <p>Java Burn 2.0 and its affiliates shall not be liable for any indirect, incidental, or consequential damages arising from the use of our website or products.</p>
    
        <h2>Changes to Terms</h2>
        <p>We reserve the right to update these Terms & Conditions at any time. Continued use of the website constitutes acceptance of the revised terms.</p>
      </section>
    </main>
</Layout>
