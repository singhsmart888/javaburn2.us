---
export interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  extraSchemas?: any[];
  noindex?: boolean;
  showStickyFooter?: boolean;
}

const {
  title,
  description,
  keywords,
  canonical,
  ogTitle,
  ogDescription,
  ogType = 'website',
  ogImage = '/assets/images/6-bottles.webp',
  extraSchemas = [],
  noindex = false,
  showStickyFooter = false,
} = Astro.props;

const siteUrl = 'https://javaburn2.us';
const pageCanonical = canonical || new URL(Astro.url.pathname, siteUrl).href;
const pageTitle = ogTitle || title;
const pageDesc = ogDescription || description;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Java Burn 2.0',
  url: siteUrl,
  logo: `${siteUrl}/assets/images/logo.png`,
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Java Burn 2.0',
  url: siteUrl,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/?s={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title set:html={title}></title>
  <meta name="description" content={description}>
  {keywords && <meta name="keywords" content={keywords}>}
  <link rel="canonical" href={pageCanonical}>
  {noindex && <meta name="robots" content="noindex, nofollow">}
  {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">}
  <meta name="author" content="Java Burn 2.0">
  <meta name="geo.region" content="US">
  <meta name="geo.placename" content="United States">
  <meta name="geo.position" content="37.09024;-95.712891">
  <meta name="ICBM" content="37.09024, -95.712891">
  <meta name="language" content="English">
  <meta name="distribution" content="global">
  <meta name="revisit-after" content="7 days">
  <meta http-equiv="content-language" content="en-us">

  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={pageDesc}>
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={pageCanonical}>
  <meta property="og:image" content={new URL(ogImage, siteUrl).href}>
  <meta property="og:site_name" content="Java Burn 2.0">
  <meta property="og:locale" content="en_US">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={pageTitle}>
  <meta name="twitter:description" content={pageDesc}>
  <meta name="twitter:image" content={new URL(ogImage, siteUrl).href}>

  <link rel="icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16x16.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5">
  <meta name="theme-color" content="#ffffff">

  <meta name="google-site-verification" content="lX8WSSHxPMboyIvhcl8-pfOamGFMY_N3lZl6z2vnkgI">
  <meta name="msvalidate.01" content="B9E7566C2A2D0384C99775C185111941">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TFDTZ9PWS0" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-TFDTZ9PWS0');
  </script>

  <link rel="stylesheet" href="/alphacur.min.css">
  <link rel="stylesheet" href="/alphacur-main.min.css">
  <link rel="stylesheet" href="/javaburn-theme.css">
  <link rel="stylesheet" href="/kw-theme.css">

  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  {extraSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
  ))}

  <slot name="head" />
</head>
